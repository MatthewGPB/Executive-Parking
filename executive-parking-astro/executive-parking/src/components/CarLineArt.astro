---
// Gold line-art luxury car — stands in for the original car artwork.
// To use the real image instead: drop the file in /public and replace this
// component with <img src="/your-car.png" ... /> in the subpage.
interface Props { label?: string; }
const { label = 'PAM Executive Parking' } = Astro.props;
---

<figure class="car-frame reveal" aria-label={label}>
  <svg viewBox="0 0 420 230" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true">
    <defs>
      <linearGradient id="goldStroke" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#f0d780"/>
        <stop offset="1" stop-color="#b38b4d"/>
      </linearGradient>
      <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="1.4" result="b"/>
        <feMerge>
          <feMergeNode in="b"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
    </defs>
    <g fill="none" stroke="url(#goldStroke)" stroke-width="1.6"
       stroke-linecap="round" stroke-linejoin="round" filter="url(#glow)">
      <!-- body -->
      <path d="M44 150
               C 60 150 70 150 86 150
               L 110 116
               C 124 100 150 92 184 92
               L 250 92
               C 286 92 312 104 332 124
               L 356 148
               C 372 149 384 150 392 154
               C 398 157 398 166 392 168
               L 360 170" />
      <path d="M44 150 C 36 150 30 156 30 162 C 30 167 34 170 40 170 L 64 170" />
      <!-- rocker -->
      <path d="M120 170 L 300 170" />
      <!-- greenhouse -->
      <path d="M118 116 L 138 98 C 150 90 168 88 188 88 L 246 88
               C 276 88 300 98 318 118 L 330 132" />
      <path d="M196 90 L 196 132 M 250 90 L 250 134" />
      <path d="M126 124 L 322 130" opacity="0.8"/>
      <!-- hood + grille lines -->
      <path d="M332 124 L 392 150" opacity="0.7"/>
      <path d="M356 148 L 392 154" opacity="0.6"/>
      <!-- door seams -->
      <path d="M168 132 L 176 168" opacity="0.55"/>
      <path d="M252 134 L 258 168" opacity="0.55"/>
      <!-- front wheel -->
      <circle cx="96" cy="172" r="30"/>
      <circle cx="96" cy="172" r="14" opacity="0.7"/>
      <!-- rear wheel -->
      <circle cx="318" cy="172" r="30"/>
      <circle cx="318" cy="172" r="14" opacity="0.7"/>
      <!-- ground reflection -->
      <path d="M70 206 L 350 206" opacity="0.3"/>
    </g>
  </svg>
</figure>

<style>
  .car-frame {
    border: 1px solid var(--gold);
    background:
      radial-gradient(120% 120% at 50% 40%, rgba(212,175,55,0.06), transparent 70%),
      var(--night-2);
    padding: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 0 60px rgba(0,0,0,0.6);
  }
  .car-frame svg { width: 100%; height: auto; }
</style>
