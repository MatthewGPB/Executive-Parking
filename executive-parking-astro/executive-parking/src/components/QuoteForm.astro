---
import { formspreeAction } from '../data/site.js';
---

<section class="inquiry" id="quote">
  <div class="wrap inquiry-inner">
    <p class="eyebrow reveal" style="text-align:center">By Invitation</p>
    <h2 class="section-title reveal" style="text-align:center; font-size: clamp(2rem, 4.6vw, 3.4rem);">
      Now Accepting Clients for the 2026–2027 Winter Season
    </h2>
    <p class="inquiry-lede reveal">
      A private inquiry reserved for those who expect perfection in every arrival and
      departure. Complete the form below and step beneath the porte-cochère.
    </p>

    <form
      class="inquiry-form reveal"
      id="inquiryForm"
      action={formspreeAction}
      method="POST"
    >
      <div class="field">
        <label for="fullName">Full Name</label>
        <input id="fullName" name="Full Name" type="text" autocomplete="name" required />
      </div>

      <div class="field-row">
        <div class="field">
          <label for="phone">Phone Number</label>
          <input id="phone" name="Phone Number" type="tel" autocomplete="tel" required />
        </div>
        <div class="field">
          <label for="email">Email Address</label>
          <input id="email" name="Email Address" type="email" autocomplete="email" required />
        </div>
      </div>

      <div class="field">
        <label for="serviceType">Service Type</label>
        <select id="serviceType" name="Service Type" required>
          <option value="" disabled selected>Select an engagement</option>
          <option>One-Time Engagement</option>
          <option>Continuous Private Service</option>
        </select>
      </div>

      <div class="field">
        <label for="address">Estate or Property Address</label>
        <input id="address" name="Estate or Property Address" type="text" autocomplete="street-address" />
      </div>

      <div class="field-row">
        <div class="field">
          <label for="company">Company / Institution Name <span class="opt">(optional)</span></label>
          <input id="company" name="Company / Institution" type="text" />
        </div>
        <div class="field">
          <label for="startDate">Preferred Date or Season Start</label>
          <input id="startDate" name="Preferred Date or Season Start" type="text" placeholder="e.g. December 2026" />
        </div>
      </div>

      <div class="field">
        <label for="notes">Additional Information or Special Requests</label>
        <textarea id="notes" name="Additional Information" rows="4"></textarea>
      </div>

      <!-- Spam honeypot (hidden from people, catches bots) -->
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" aria-hidden="true" />

      <div class="submit-wrap">
        <button class="btn-gold" type="submit" id="inquirySubmit">Send Inquiry to the Porte-Cochère</button>
      </div>
    </form>

    <div class="inquiry-success" id="inquirySuccess" hidden>
      <h3>Your request has been received with the utmost discretion.</h3>
      <p>
        A member of our private team will respond promptly, as one would expect beneath
        the lanterns of the finest estates. Thank you for trusting Executive Parking
        with your arrivals.
      </p>
    </div>
  </div>
</section>

<style>
  .inquiry {
    background: var(--night-2);
    padding: clamp(70px, 10vw, 130px) 0;
    border-top: 1px solid rgba(212,175,55,0.1);
  }
  .inquiry-inner { max-width: 860px; }
  .inquiry-lede {
    text-align: center;
    font-style: italic;
    color: var(--text);
    font-size: clamp(1.02rem, 2vw, 1.24rem);
    max-width: 640px;
    margin: 20px auto clamp(40px, 6vw, 64px);
  }

  .inquiry-form {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
  }
  .field { display: flex; flex-direction: column; gap: 8px; }
  .field label {
    font-family: var(--font-body);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold-soft);
  }
  .opt { text-transform: none; letter-spacing: 0.02em; color: var(--text-dim); font-style: italic; }

  .field input,
  .field select,
  .field textarea {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--paper);
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(212,175,55,0.28);
    padding: 14px 16px;
    transition: border-color 0.4s var(--ease), background 0.4s var(--ease);
    width: 100%;
  }
  .field textarea { resize: vertical; }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--gold);
    background: rgba(212,175,55,0.05);
  }
  .field select option { background: var(--night-2); color: var(--paper); }

  .submit-wrap { text-align: center; margin-top: 14px; }
  #inquirySubmit:disabled { opacity: 0.5; cursor: default; }

  .inquiry-success {
    text-align: center;
    padding: 40px 10px;
    animation: fadeIn 0.9s var(--ease);
  }
  .inquiry-success[hidden] { display: none; }
  .inquiry-success h3 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    margin-bottom: 18px;
  }
  .inquiry-success p {
    color: var(--text);
    font-style: italic;
    max-width: 600px;
    margin: 0 auto;
  }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: none; } }

  @media (max-width: 640px) {
    .field-row { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  (function () {
    var form = document.getElementById('inquiryForm');
    var success = document.getElementById('inquirySuccess');
    var btn = document.getElementById('inquirySubmit');
    if (!form) return;

    form.addEventListener('submit', function (e) {
      // If the Formspree endpoint hasn't been set yet, let it submit normally
      // so the placeholder is obvious; otherwise do a smooth AJAX submit.
      if (form.action.indexOf('YOUR_FORM_ID') !== -1) {
        e.preventDefault();
        alert('Heads up: add your Formspree form ID in src/data/site.js to enable delivery.');
        return;
      }

      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Sending…';

      fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      })
        .then(function (res) {
          if (res.ok) {
            form.hidden = true;
            success.hidden = false;
            success.scrollIntoView({ behavior: 'smooth', block: 'center' });
          } else {
            throw new Error('Submission failed');
          }
        })
        .catch(function () {
          btn.disabled = false;
          btn.textContent = 'Send Inquiry to the Porte-Cochère';
          alert('Something went wrong sending your inquiry. Please call (561) 377-7704.');
        });
    });
  })();
</script>
