---
// Shared closing CTA — "Begin Your Private Valet Journey"
---
<section class="journey">
  <div class="wrap">
    <h2 class="section-title reveal" style="text-align:center; font-size: clamp(2rem,4.6vw,3.4rem);">
      Begin Your Private Valet Journey
    </h2>
    <p class="journey-lede reveal">
      Now accepting clients for the 2026–2027 winter season.
      Let us welcome you where you belong.
    </p>
    <div class="reveal" style="text-align:center">
      <a class="btn-gold" href="/#quote">Request a Quote</a>
    </div>
  </div>
</section>

<style>
  .journey {
    background: var(--night-2);
    padding: clamp(70px, 10vw, 120px) 0;
    border-top: 1px solid rgba(212,175,55,0.1);
  }
  .journey-lede {
    text-align: center;
    font-style: italic;
    color: var(--text);
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    max-width: 540px;
    margin: 20px auto 38px;
  }
</style>
