---
import { site, careersMailto } from '../data/site.js';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <hr class="hairline" />
  <div class="footer-inner">
    <p class="footer-copy">
      Executive Parking © {year} • Palm Beach &amp; South Florida
    </p>
    <nav class="footer-links" aria-label="Footer">
      <!-- These three still resolve to the existing pages; update the hrefs
           once the Terms / Privacy / Designation pages move to the new host. -->
      <a href="https://executive-parking.myshopify.com/pages/terms-of-service">Terms</a>
      <span class="dot">|</span>
      <a href="https://executiveparkingpb.com/pages/privacy-policy">Privacy</a>
      <span class="dot">|</span>
      <a href="https://executiveparkingpb.com/pages/designation-form">Designation Form</a>
      <span class="dot">|</span>
      <a href={careersMailto}>Careers</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--night-2);
    padding: 0 0 38px;
  }
  .footer-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 34px clamp(20px, 5vw, 64px) 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px 28px;
  }
  .footer-copy {
    margin: 0;
    color: var(--text-dim);
    font-size: 0.9rem;
    letter-spacing: 0.08em;
  }
  .footer-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    font-size: 0.86rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .footer-links a {
    color: var(--gold-soft);
    transition: color 0.4s var(--ease);
  }
  .footer-links a:hover { color: var(--gold); }
  .dot { color: rgba(212, 175, 55, 0.35); }

  @media (max-width: 620px) {
    .footer-inner { flex-direction: column; align-items: center; text-align: center; }
    .footer-links { justify-content: center; }
  }
</style>
